# ─── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://bizbot:bizbot_dev_password@localhost:5432/bizbot
DATABASE_URL_SYNC=postgresql://bizbot:bizbot_dev_password@localhost:5432/bizbot

# ─── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT ────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_random_64_char_hex_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Google Gemini ───────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
GEMINI_CHAT_MODEL=gemini-2.5-flash

# ─── Pinecone ───────────────────────────────────────────────────
# Get from: https://app.pinecone.io
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=bizbot

# ─── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
