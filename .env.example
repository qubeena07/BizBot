# ===========================================
# BizBot AI — Environment Variables
# ===========================================
# Copy this file to .env and fill in values

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://bizbot:bizbot_dev_password@localhost:5432/bizbot
DATABASE_URL_SYNC=postgresql://bizbot:bizbot_dev_password@localhost:5432/bizbot

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Auth / JWT ----
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- NextAuth ----
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-random-secret

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Gemini ----
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
GEMINI_CHAT_MODEL=gemini-1.5-flash

# ---- Pinecone ----
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=bizbot-knowledge

# ---- API ----
API_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:3000"]
